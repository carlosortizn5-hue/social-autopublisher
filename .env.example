# Database
DATABASE_URL=postgresql://user:password@localhost:5432/social_autopublisher

# Redis
REDIS_URL=redis://localhost:6379/0

# App
IS_PRODUCTION=0
POSTS_PER_DAY=3
PIPELINE_INTERNAL_TOKEN=your-secret-token
LOG_LEVEL=INFO

# Mercado Libre
ML_CLIENT_ID=your-ml-client-id
ML_CLIENT_SECRET=your-ml-client-secret
ML_REFRESH_TOKEN=your-ml-refresh-token
ML_AFFILIATE_TAG=your-ml-tag
ML_SITE_ID=MLM
ML_SEARCH_QUERY=electrónica ofertas

# Twitter / X
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret
X_BEARER_TOKEN=your-x-bearer-token

# Meta (Instagram + Facebook)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_LONG_LIVED_TOKEN=your-meta-long-lived-token
IG_BUSINESS_ACCOUNT_ID=your-ig-account-id
FB_PAGE_ID=your-fb-page-id
